{
  "name": "ai-code-trace-agent",
  "version": "0.0.1",
  "private": true,
  "description": "Local AI code trace agent for tracking codebase flow",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
